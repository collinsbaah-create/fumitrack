  <line x1="256" y1="240" x2="256" y2="380" stroke="#1A3A2A" stroke-width="5" stroke-linecap="round"/>
  <!-- Grain dots on bag -->
  <circle cx="180" cy="370" r="10" fill="#92400E" opacity="0.6"/>
  <circle cx="210" cy="395" r="8" fill="#92400E" opacity="0.5"/>
  <circle cx="300" cy="365" r="11" fill="#92400E" opacity="0.6"/>
  <circle cx="330" cy="390" r="8" fill="#92400E" opacity="0.5"/>
  <!-- FT monogram -->
  <text x="256" y="470" font-family="'Space Grotesk', Arial, sans-serif" font-size="44" font-weight="700" fill="white" text-anchor="middle" opacity="0.9">FumiTrack</text>
