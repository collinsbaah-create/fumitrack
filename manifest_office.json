<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 512 512" width="512" height="512">
  <!-- Background rounded rect -->
  <rect width="512" height="512" rx="112" fill="#1A3A2A"/>
  <!-- Bag body -->
  <rect x="116" y="200" width="280" height="220" rx="28" fill="#D4860B"/>
  <!-- Bag neck -->
  <rect x="176" y="155" width="160" height="60" rx="14" fill="#B8720A"/>
